msgid "Snippet"
msgstr "スニペット"

msgid "Topbar Snips"
msgstr "Topbar Snips"

msgid "Topbar Snips lets you pick snippets from the GNOME Shell top bar, copy them, and try to paste automatically when possible."
msgstr "Topbar Snips は GNOME Shell のトップバーからスニペットを選び、コピーし、可能なら自動貼り付けを試みます。"

msgid "Snip"
msgstr "切貼"

msgid "Automatic paste failed. The snippet is still in the clipboard."
msgstr "自動貼り付けに失敗しました。スニペットはクリップボードに残っています。"

msgid "Copied"
msgstr "コピーしました"

msgid "Trying to paste"
msgstr "貼り付けを試行中"

msgid "Search snippets..."
msgstr "スニペットを検索..."

msgid "Snippet not found for deletion"
msgstr "削除対象のスニペットが見つかりません"

msgid "Deleted"
msgstr "削除しました"

msgid "Failed to delete"
msgstr "削除に失敗しました"

msgid "Delete..."
msgstr "削除..."

msgid "Open snippets.txt"
msgstr "snippets.txt を開く"

msgid "Opened"
msgstr "開きました"

msgid "Failed to open snippets.txt"
msgstr "snippets.txt を開けませんでした"

msgid "Open Preferences"
msgstr "環境設定を開く"

msgid "Failed to read the snippet file."
msgstr "スニペットファイルを読み込めませんでした。"

msgid "No snippets available."
msgstr "利用できるスニペットがありません。"

msgid "No matching snippets."
msgstr "一致するスニペットがありません。"

msgid "Open the menu with a shortcut, search, and press Enter to paste."
msgstr "ショートカットでメニューを開き、検索して Enter で貼り付けます。"

msgid "Open Topbar Snips"
msgstr "Topbar Snips を開く"

msgid "Use the Up and Down keys to choose a snippet, then press Enter."
msgstr "上下キーでスニペットを選び、Enter を押します。"

msgid "Keyboard"
msgstr "キーボード"

msgid "Behavior"
msgstr "動作"

msgid "Keep snippet in clipboard after activation"
msgstr "確定後もスニペットをクリップボードに残す"

msgid "When off, the clipboard is swapped temporarily for pasting and restored after Ctrl+V is sent."
msgstr "オフのときは貼り付けのために一時的にクリップボードを差し替え、Ctrl+V 送出後に元へ戻します。"

msgid "Show notifications"
msgstr "通知を表示する"

msgid "Show notifications for copy, paste, deletion, and file opening actions."
msgstr "コピー、貼り付け、削除、ファイルを開く操作で通知を表示します。"

msgid "Shortcut to open Topbar Snips"
msgstr "Topbar Snips を開くショートカット"

msgid ""
"Keyboard accelerator used to open Topbar Snips and focus the\n"
"search field."
msgstr ""
"Topbar Snips を開き、検索欄へフォーカスするための\n"
"キーボードショートカットです。"

msgid "Whether activating a snippet should keep the snippet text in the clipboard after attempting automatic paste."
msgstr "スニペット確定時に自動貼り付けを試したあと、その本文をクリップボードに残すかどうかです。"

msgid "Show notifications for snippet actions"
msgstr "スニペット操作の通知を表示する"

msgid ""
"Whether snippet activation, deletion, file opening, and paste failure\n"
"should show desktop notifications."
msgstr ""
"スニペットの確定、削除、ファイルを開く操作、自動貼り付け失敗時に\n"
"デスクトップ通知を表示するかどうかです。"
